# ─────────────────────────────────────────────
#  hoWrk — Environment Variables Template
#  Copy this file to .env and fill in your values.
#  Never commit the actual .env file!
# ─────────────────────────────────────────────

# Twilio — used for emergency SOS calls & guardian alerts
TWILIO_SID=your_twilio_account_sid_here
TWILIO_TOKEN=your_twilio_auth_token_here
TWILIO_FROM=+1XXXXXXXXXX
ASSISTANCE_TO=+91XXXXXXXXXX

# Firebase — service account credentials path
GOOGLE_APPLICATION_CREDENTIALS=./backend/firebase-key.json

# JWT Auth
SECRET_KEY=your_super_secret_jwt_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=60

# App
APP_URL=http://localhost:8000
